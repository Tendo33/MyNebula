# ============================================================
# MyNebula 环境变量完整模板
# 使用方法: cp .env.example .env && 按需修改
# ============================================================

# ==================== 必填项 (Must Configure) ====================

# GitHub Personal Access Token
# 创建地址: https://github.com/settings/tokens
# 建议权限: read:user, public_repo
GITHUB_TOKEN=your_github_personal_access_token

# ==================== Embedding 服务配置 ====================

# 向量化必需，默认 SiliconFlow，也支持 OpenAI / Jina / Ollama 等 OpenAI 兼容接口
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSIONS=1024

# ==================== LLM 服务配置（可选，推荐） ====================

# 用于摘要、标签和聚类命名
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_OUTPUT_LANGUAGE=zh

# ==================== 数据库配置 ====================

# Docker Compose 部署常用三项
DATABASE_USER=mynebula
DATABASE_PASSWORD=mynebula_secret
DATABASE_NAME=mynebula

# 本地开发或外部数据库时可配置（Compose 内部 API 默认连接 db:5432）
DATABASE_HOST=localhost
DATABASE_PORT=5432

# 完整连接串优先级最高（设置后会覆盖 host/port/user/password/name）
# 例: postgresql://mynebula:mynebula_secret@localhost:5432/mynebula
DATABASE_URL=

# ==================== 应用配置 ====================

# 对外访问端口映射（http://localhost:${API_PORT}）
API_PORT=8000
APP_NAME=mynebula
APP_VERSION=1.2.5
DEBUG=false

# 跨域来源，多个来源用逗号分隔；留空时仅允许 localhost / 127.0.0.1
CORS_ORIGINS=

# 是否启用单用户模式（默认 true）
SINGLE_USER_MODE=true

# 图谱快照读取失败时是否回退到实时构建
SNAPSHOT_READ_FALLBACK_ON_ERROR=true

# 慢查询日志阈值（毫秒）
SLOW_QUERY_LOG_MS=200

# 图谱查询超时时间（秒）
API_QUERY_TIMEOUT_SECONDS=15

# 读接口访问模式: demo / authenticated
# demo: 匿名只读，适合本地演示
# authenticated: 读接口也要求管理员登录
READ_ACCESS_MODE=demo

# ==================== 管理员访问控制 ====================

# /settings 以及写操作保护
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# 管理员登录会话有效期（小时）
ADMIN_SESSION_TTL_HOURS=24

# 管理员登录失败限流
ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ADMIN_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# 生产环境可强制开启 Secure Cookie
FORCE_SECURE_COOKIES=false

# 反向代理 / TLS 终止场景支持
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
TRUSTED_HOSTS=
HTTPS_REDIRECT=false

# 如需启用 CSP，请填入完整 header 值
CONTENT_SECURITY_POLICY=

# ==================== 日志配置 ====================

# 日志级别: TRACE / DEBUG / INFO / SUCCESS / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==================== 同步配置 ====================

# Star 同步批次大小（10~500）
SYNC_BATCH_SIZE=100

# README 最大抓取长度（字符，1000~100000）
SYNC_README_MAX_LENGTH=10000

# 默认同步模式: incremental / full
SYNC_DEFAULT_SYNC_MODE=incremental

# 增量同步时是否检测“已取消 Star”的仓库（会增加 API 开销）
SYNC_DETECT_UNSTARRED_ON_INCREMENTAL=false

# ==================== 说明 ====================

# 1. 管理员鉴权只有在 ADMIN_PASSWORD 和 ADMIN_SESSION_SECRET 同时非空时才会启用
# 2. 前端开发时如果要让 Vite 代理到本地后端，可这样启动：
#    VITE_API_BASE_URL=http://localhost:8000 npm --prefix frontend run dev
# 3. 生产环境请配置强密码、随机 ADMIN_SESSION_SECRET，并启用 HTTPS / Secure Cookie
# 4. 如果启用 TRUST_PROXY_HEADERS，请同时填写 TRUSTED_PROXY_IPS，限制可注入 X-Forwarded-* 的代理来源
# 5. 如果你准备公网部署，推荐至少组合开启：
#    READ_ACCESS_MODE=authenticated
#    FORCE_SECURE_COOKIES=true
#    TRUST_PROXY_HEADERS=true
#    TRUSTED_PROXY_IPS=<your reverse proxy IPs>
